# Optional local-model planner via Ollama (model-by-intent routing).
# Leave both model vars empty for deterministic local-only mode.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_SMALL=
OLLAMA_MODEL_LARGE=

# Backend port used by Vite proxy.
PORT=8787

# Confidence policy for command clarification gate.
INTENT_CLARIFICATION_THRESHOLD=0.65

# Continuity telemetry budget for handoff claim latency.
HANDOFF_LATENCY_BUDGET_MS=500

# Minimum interval for persisted presence heartbeat writes (ms).
PRESENCE_WRITE_MIN_INTERVAL_MS=15000

# Max continuity snapshots retained per session.
CONTINUITY_HISTORY_MAX_ENTRIES=300

# Anomaly detection settings for continuity trend analysis.
CONTINUITY_ANOMALY_WINDOW=120
CONTINUITY_ANOMALY_SCORE_DROP=15

# Continuity autopilot cooldown between automatic remediation ticks.
CONTINUITY_AUTOPILOT_COOLDOWN_MS=30000

# Max continuity autopilot history events retained per session.
CONTINUITY_AUTOPILOT_HISTORY_MAX=200

# Max automatic continuity actions autopilot may apply per rolling hour.
CONTINUITY_AUTOPILOT_MAX_APPLIES_PER_HOUR=30
