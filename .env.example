# GenomeUI — Environment Variables
# Copy to .env and fill in values. None of these are required for scaffold/mock mode.

# ── OAuth redirect base ────────────────────────────────────────────────────────
# Must match the redirect URI registered in each provider's OAuth app settings.
# Callback URL = {OAUTH_REDIRECT_BASE}/api/connectors/oauth/{service}/callback
OAUTH_REDIRECT_BASE=http://localhost:5173

# ── Spotify ───────────────────────────────────────────────────────────────────
# Register app at: https://developer.spotify.com/dashboard
# Redirect URI to add: http://localhost:5173/api/connectors/oauth/spotify/callback
# Scopes needed: user-read-playback-state user-modify-playback-state user-read-currently-playing
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Google (Gmail + Calendar + Drive — can share one OAuth app) ───────────────
# Create project at: https://console.cloud.google.com
# Enable APIs: Gmail API, Google Calendar API, Google Drive API
# Redirect URI to add: http://localhost:5173/api/connectors/oauth/gmail/callback
#                      http://localhost:5173/api/connectors/oauth/gcal/callback
#                      http://localhost:5173/api/connectors/oauth/gdrive/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create app at: https://api.slack.com/apps
# Redirect URI to add: http://localhost:5173/api/connectors/oauth/slack/callback
# Scopes: channels:read channels:history chat:write
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Plaid (banking) ───────────────────────────────────────────────────────────
# Sign up at: https://dashboard.plaid.com/
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Provider modes (auto = use vault token if present, else scaffold) ──────────
# Leave as "auto" — set to "live" only to force live mode without a vault token.
SPOTIFY_PROVIDER_MODE=auto
GMAIL_PROVIDER_MODE=auto
GCAL_PROVIDER_MODE=auto
GDRIVE_PROVIDER_MODE=auto
SLACK_PROVIDER_MODE=auto
PLAID_PROVIDER_MODE=scaffold

# ── Genome Relay (internet-tier transport + mobile wakeup) ────────────────────
# Set GENOME_RELAY_URL to connect this node to a relay server on startup.
# Enables delivery to mobile devices (iOS/Android) and cross-NAT peers.
GENOME_RELAY_URL=

# Run your own relay: cd Nous && npm run relay
# Relay server config (used when running relay_server.ts):
GENOME_RELAY_SEED_HEX=
GENOME_RELAY_PORT=9090
GENOME_RELAY_PUBLIC_URL=

# APNs (iOS push notifications — wake sleeping iOS devices)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8_PATH=
APNS_BUNDLE_ID=
APNS_SANDBOX=true

# FCM (Android push notifications — wake sleeping Android devices)
FCM_SERVICE_ACCOUNT=

# ── Twilio (PSTN calling) ──────────────────────────────────────────────────────
# Sign up at: https://www.twilio.com/console
# Buy a phone number with Voice capability (E.164 format: +1XXXXXXXXXX)
# Then "grant connector scope telephony.call.start" in GenomeUI to enable calling.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public URL this backend is reachable at — Twilio posts webhooks here.
# For local dev: use ngrok or similar ( ngrok http 8787 )
# Then set: GENOME_TELEPHONY_WEBHOOK_URL=https://<your-ngrok-id>.ngrok-free.app
GENOME_TELEPHONY_WEBHOOK_URL=

# ── E911 (emergency calling — required in most US jurisdictions) ───────────────
# Register your physical address via:  POST /api/telephony/e911
# Body: { "address": "123 Main St", "city": "Springfield", "state": "IL", "zip": "62701" }
# This associates an emergency address with TWILIO_PHONE_NUMBER in Twilio's system.
# Required fields are validated; Twilio will reject calls to 911 without a registered address.
